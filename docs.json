{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "My Docs",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "icon": "book-open",
        "pages": [
          "index",
          {
            "group": "Study",
            "icon": "book-open",
            "root": "study/index",
            "pages": [
              "study/isaac-sim",
              "study/isaac-lab",
              "study/robotics"
            ]
          }
        ]
      },
      {
        "tab": "Troubleshooting",
        "icon": "wrench",
        "pages": [
          "troubleshooting/index",
          {
            "group": "Isaac",
            "icon": "cube",
            "root": "troubleshooting/isaac/index",
            "pages": [
              "troubleshooting/isaac/isaac-sim",
              "troubleshooting/isaac/isaac-lab"
            ]
          }
        ]
      },
      {
        "tab": "Refs",
        "icon": "bookmark",
        "pages": [
          "references/index"
        ]
      },
      {
        "tab": "Personal",
        "icon": "user",
        "pages": [
          "personal/index",
          {
            "group": "Projects",
            "icon": "folder-open",
            "root": "projects/index",
            "pages": [
              "projects/portfolio"
            ]
          },
          {
            "group": "Setup",
            "icon": "laptop",
            "root": "setup/index",
            "pages": [
              "setup/setup"
            ]
          }
        ]
      }
    ]
  },
  "redirects": [
    { "source": "/quickstart", "destination": "/" },
    { "source": "/whats-this", "destination": "/" },
    { "source": "/documentations/whats-this", "destination": "/" },
    { "source": "/study-notes", "destination": "/study" },
    { "source": "/study-notes/isaac-sim", "destination": "/study/isaac-sim" },
    { "source": "/study-notes/isaac-lab", "destination": "/study/isaac-lab" },
    { "source": "/study-notes/robotics", "destination": "/study/robotics" },
    { "source": "/blog", "destination": "/troubleshooting" },
    { "source": "/troubleshooting/isaac-sim", "destination": "/troubleshooting/isaac/isaac-sim" },
    { "source": "/troubleshooting/isaac-lab", "destination": "/troubleshooting/isaac/isaac-lab" },
    { "source": "/troubleshooting/dev-env", "destination": "/troubleshooting" },
    { "source": "/troubleshooting/general", "destination": "/troubleshooting" },
    { "source": "/snippets", "destination": "/personal/snippets" },
    { "source": "/daily-log", "destination": "/personal/daily-log" },
    { "source": "/portfolio", "destination": "/projects/portfolio" },
    { "source": "/personal/portfolio", "destination": "/projects/portfolio" }
  ],
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.mintlify.com"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/mintlify",
      "github": "https://github.com/mintlify",
      "linkedin": "https://linkedin.com/company/mintlify"
    }
  }
}